# Copy file này thành .env.local và điền API key của bạn
# Vite tự động đọc .env.local và KHÔNG commit lên git

# Google Gemini API Key — lấy tại https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIza...your-key-here...

# DeepSeek API Key — lấy tại https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=sk-...your-key-here...

# HuggingFace User Access Token — lấy tại https://huggingface.co/settings/tokens
VITE_HF_API_KEY=hf_...your-token-here...

# Model sử dụng cho chatbot (để trống = dùng mặc định: meta-llama/Llama-3.3-70B-Instruct)
# Các lựa chọn:
#   meta-llama/Llama-3.3-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
#   mistralai/Mistral-7B-Instruct-v0.3
#   google/gemma-3-27b-it
#   deepseek-ai/DeepSeek-R1
VITE_HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
